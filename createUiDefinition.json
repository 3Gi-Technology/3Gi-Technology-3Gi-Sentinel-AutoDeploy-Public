{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": true,
      "basics": {
        "description": "Deploy a 3Gi Microsoft Sentinel landing zone for an MSSP client."
      }
    },
    "basics": [
      {
        "name": "clientName",
        "type": "Microsoft.Common.TextBox",
        "label": "Client display name",
        "defaultValue": "",
        "toolTip": "Full customer/client name used for tagging and reporting.",
        "constraints": { "required": true, "regex": "^[a-zA-Z0-9 ._-]{2,50}$", "validationMessage": "Enter a valid client name." }
      },
      {
        "name": "clientCode",
        "type": "Microsoft.Common.TextBox",
        "label": "Client code",
        "defaultValue": "",
        "toolTip": "Short lowercase code used in resource names, for example ashtons.",
        "constraints": { "required": true, "regex": "^[a-z0-9-]{2,20}$", "validationMessage": "Use lowercase letters, numbers and hyphens only." }
      },
      {
        "name": "environment",
        "type": "Microsoft.Common.DropDown",
        "label": "Environment",
        "defaultValue": "prod",
        "toolTip": "Deployment environment.",
        "constraints": { "allowedValues": [ { "label": "Production", "value": "prod" }, { "label": "Test", "value": "test" }, { "label": "Development", "value": "dev" }, { "label": "Lab", "value": "lab" } ], "required": true }
      },
      {
        "name": "location",
        "type": "Microsoft.Common.LocationSelector",
        "label": "Region",
        "toolTip": "Azure region for the Sentinel resource group and workspace.",
        "resourceTypes": ["Microsoft.OperationalInsights/workspaces"],
        "defaultValue": "ukwest"
      },
      {
        "name": "regionCode",
        "type": "Microsoft.Common.TextBox",
        "label": "Region code",
        "defaultValue": "ukw",
        "toolTip": "Short region code used in names, for example ukw or uks.",
        "constraints": { "required": true, "regex": "^[a-z0-9]{2,6}$", "validationMessage": "Use a short lowercase region code." }
      }
    ],
    "steps": [
      {
        "name": "workspaceSettings",
        "label": "Workspace",
        "elements": [
          { "name": "resourceGroupName", "type": "Microsoft.Common.TextBox", "label": "Resource group name override", "defaultValue": "", "toolTip": "Leave blank to use rg-3gi-sentinel-<clientCode>-<environment>-<regionCode>." },
          { "name": "workspaceName", "type": "Microsoft.Common.TextBox", "label": "Workspace name override", "defaultValue": "", "toolTip": "Leave blank to use law-3gi-sentinel-<clientCode>-<environment>-<regionCode>." },
          { "name": "retentionInDays", "type": "Microsoft.Common.Slider", "label": "Retention in days", "min": 30, "max": 730, "defaultValue": 90, "showStepMarkers": false },
          { "name": "dailyQuotaGb", "type": "Microsoft.Common.TextBox", "label": "Daily cap GB", "defaultValue": "-1", "toolTip": "Use -1 for no cap." }
        ]
      },
      {
        "name": "sentinelSettings",
        "label": "Sentinel settings",
        "elements": [
          { "name": "enableUeba", "type": "Microsoft.Common.CheckBox", "label": "Enable UEBA", "defaultValue": true },
          { "name": "enableSentinelHealth", "type": "Microsoft.Common.CheckBox", "label": "Enable Sentinel health settings", "defaultValue": true },
          { "name": "enable3GiSocBaseline", "type": "Microsoft.Common.CheckBox", "label": "Enable 3Gi SOC baseline", "defaultValue": true }
        ]
      },
      {
        "name": "licensingAndConnectors",
        "label": "Licensing and connectors",
        "elements": [
          {
            "name": "licenceProfile",
            "type": "Microsoft.Common.DropDown",
            "label": "Client licence profile",
            "defaultValue": "Custom",
            "toolTip": "Used as an engineer-facing guide for connector selection.",
            "constraints": { "allowedValues": [ { "label": "Basic Azure Only", "value": "BasicAzureOnly" }, { "label": "Microsoft 365 Business Premium", "value": "M365BusinessPremium" }, { "label": "Microsoft 365 E3", "value": "M365E3" }, { "label": "Microsoft 365 E5", "value": "M365E5" }, { "label": "Defender for Cloud", "value": "DefenderForCloud" }, { "label": "Custom", "value": "Custom" } ], "required": true }
          },
          { "name": "enableAzureActivity", "type": "Microsoft.Common.CheckBox", "label": "Enable Azure Activity via diagnostic settings", "defaultValue": true },
          { "name": "enableEntraDiagnostics", "type": "Microsoft.Common.CheckBox", "label": "Enable Entra diagnostic logs", "defaultValue": true },
          {
            "name": "entraLogCategories",
            "type": "Microsoft.Common.OptionsGroup",
            "label": "Entra log categories",
            "defaultValue": ["AuditLogs", "SignInLogs", "NonInteractiveUserSignInLogs", "ServicePrincipalSignInLogs", "ManagedIdentitySignInLogs"],
            "toolTip": "Select logs to export to the Sentinel workspace where tenant permissions allow it.",
            "constraints": { "allowedValues": [ { "label": "AuditLogs", "value": "AuditLogs" }, { "label": "SignInLogs", "value": "SignInLogs" }, { "label": "NonInteractiveUserSignInLogs", "value": "NonInteractiveUserSignInLogs" }, { "label": "ServicePrincipalSignInLogs", "value": "ServicePrincipalSignInLogs" }, { "label": "ManagedIdentitySignInLogs", "value": "ManagedIdentitySignInLogs" }, { "label": "ProvisioningLogs", "value": "ProvisioningLogs" }, { "label": "RiskyUsers", "value": "RiskyUsers" }, { "label": "UserRiskEvents", "value": "UserRiskEvents" } ] }
          },
          { "name": "enableOffice365Connector", "type": "Microsoft.Common.CheckBox", "label": "Enable Office 365 connector", "defaultValue": false },
          { "name": "enableDefenderForCloudConnector", "type": "Microsoft.Common.CheckBox", "label": "Enable Defender for Cloud connector", "defaultValue": false },
          {
            "name": "defenderXdrMode",
            "type": "Microsoft.Common.DropDown",
            "label": "Defender XDR handling",
            "defaultValue": "Skip",
            "toolTip": "Do not blindly enable Defender XDR. Use Manual unless primary workspace behaviour has been confirmed.",
            "constraints": { "allowedValues": [ { "label": "Skip", "value": "Skip" }, { "label": "Manual onboarding step", "value": "Manual" }, { "label": "Primary workspace confirmed", "value": "PrimaryWorkspaceConfirmed" } ], "required": true }
          },
          { "name": "enableThreatIntelligenceConnector", "type": "Microsoft.Common.CheckBox", "label": "Enable Threat Intelligence connector", "defaultValue": false },
          { "name": "enableDynamicsConnector", "type": "Microsoft.Common.CheckBox", "label": "Enable Dynamics connector", "defaultValue": false }
        ]
      },
      {
        "name": "contentAndRules",
        "label": "Content and detections",
        "elements": [
          { "name": "contentSolutionNames", "type": "Microsoft.Common.TextBox", "label": "Content Hub solutions", "defaultValue": "", "toolTip": "Comma-separated solution names. v0.1 records this selection; solution install automation will be implemented in the next iteration." },
          { "name": "enableAnalyticsRules", "type": "Microsoft.Common.CheckBox", "label": "Enable analytics rules", "defaultValue": false },
          { "name": "analyticsRuleSeverities", "type": "Microsoft.Common.OptionsGroup", "label": "Analytics rule severities", "defaultValue": ["High", "Medium"], "constraints": { "allowedValues": [ { "label": "High", "value": "High" }, { "label": "Medium", "value": "Medium" }, { "label": "Low", "value": "Low" }, { "label": "Informational", "value": "Informational" } ] } },
          { "name": "enableJiraIntegration", "type": "Microsoft.Common.CheckBox", "label": "Enable Jira/PSA integration placeholder", "defaultValue": false }
        ]
      }
    ],
    "outputs": {
      "clientName": "[basics('clientName')]",
      "clientCode": "[basics('clientCode')]",
      "environment": "[basics('environment')]",
      "location": "[basics('location')]",
      "regionCode": "[basics('regionCode')]",
      "resourceGroupName": "[steps('workspaceSettings').resourceGroupName]",
      "workspaceName": "[steps('workspaceSettings').workspaceName]",
      "retentionInDays": "[steps('workspaceSettings').retentionInDays]",
      "dailyQuotaGb": "[int(steps('workspaceSettings').dailyQuotaGb)]",
      "enableUeba": "[steps('sentinelSettings').enableUeba]",
      "enableSentinelHealth": "[steps('sentinelSettings').enableSentinelHealth]",
      "enable3GiSocBaseline": "[steps('sentinelSettings').enable3GiSocBaseline]",
      "enableAzureActivity": "[steps('licensingAndConnectors').enableAzureActivity]",
      "enableEntraDiagnostics": "[steps('licensingAndConnectors').enableEntraDiagnostics]",
      "entraLogCategories": "[steps('licensingAndConnectors').entraLogCategories]",
      "enableOffice365Connector": "[steps('licensingAndConnectors').enableOffice365Connector]",
      "enableDefenderForCloudConnector": "[steps('licensingAndConnectors').enableDefenderForCloudConnector]",
      "defenderXdrMode": "[steps('licensingAndConnectors').defenderXdrMode]",
      "enableThreatIntelligenceConnector": "[steps('licensingAndConnectors').enableThreatIntelligenceConnector]",
      "enableDynamicsConnector": "[steps('licensingAndConnectors').enableDynamicsConnector]",
      "contentSolutionNames": "[split(steps('contentAndRules').contentSolutionNames, ',')]",
      "enableAnalyticsRules": "[steps('contentAndRules').enableAnalyticsRules]",
      "analyticsRuleSeverities": "[steps('contentAndRules').analyticsRuleSeverities]",
      "enableJiraIntegration": "[steps('contentAndRules').enableJiraIntegration]"
    }
  }
}
